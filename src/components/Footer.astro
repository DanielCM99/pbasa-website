---
const currentYear = new Date().getFullYear();
---

<footer class="bg-navy-950 text-white">
  <!-- Main footer -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <a href="/" class="inline-block mb-6">
          <img src="/images/logo.png" alt="PBASA Lions Logo" class="h-28 w-auto" />
        </a>
        <p class="text-navy-300 text-sm leading-relaxed">
          Empowering every student to reach their full potential through classical academics, the arts, and athletics.
        </p>
        <div class="flex gap-2 mt-6">
          <span class="inline-block w-2 h-2 rounded-full bg-gold-500"></span>
          <span class="inline-block w-2 h-2 rounded-full bg-gold-500"></span>
          <span class="inline-block w-2 h-2 rounded-full bg-gold-500"></span>
          <span class="inline-block w-2 h-2 rounded-full bg-gold-500"></span>
          <span class="inline-block w-2 h-2 rounded-full bg-gold-500"></span>
        </div>
        <p class="text-gold-400 text-xs font-semibold tracking-wider mt-2">LOYALTY &middot; INTEGRITY &middot; OPTIMISM &middot; NOBILITY &middot; STRENGTH</p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-gold-400 font-semibold text-sm uppercase tracking-wider mb-6">Quick Links</h3>
        <ul class="space-y-3">
          <li><a href="/about" class="text-navy-300 hover:text-white transition-colors text-sm">About Us</a></li>
          <li><a href="/academics" class="text-navy-300 hover:text-white transition-colors text-sm">Academics</a></li>
          <li><a href="/athletics" class="text-navy-300 hover:text-white transition-colors text-sm">Athletics</a></li>
          <li><a href="/enrollment" class="text-navy-300 hover:text-white transition-colors text-sm">Enrollment</a></li>
          <li><a href="/support-and-sponsorship" class="text-gold-400 hover:text-gold-300 transition-colors text-sm font-semibold">Support and Sponsorship</a></li>
          <li><a href="/dress-code" class="text-navy-300 hover:text-white transition-colors text-sm">Dress Code</a></li>
          <li><a href="/code-of-conduct" class="text-navy-300 hover:text-white transition-colors text-sm">Code of Conduct</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-gold-400 font-semibold text-sm uppercase tracking-wider mb-6">Contact Us</h3>
        <ul class="space-y-4">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-gold-500 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span class="text-navy-300 text-sm">5500 Village Blvd<br />West Palm Beach, FL 33407</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-gold-500 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <div>
              <a href="mailto:contact@pbasa.org" class="text-navy-300 hover:text-white transition-colors text-sm block">contact@pbasa.org</a>
              <a href="mailto:employment@pbasa.org" class="text-navy-300 hover:text-white transition-colors text-sm block mt-1">employment@pbasa.org</a>
            </div>
          </li>
        </ul>
      </div>

      <!-- Enroll CTA -->
      <div>
        <h3 class="text-gold-400 font-semibold text-sm uppercase tracking-wider mb-6">Join Our Community</h3>
        <p class="text-navy-300 text-sm mb-6">Now accepting pre-enrollment applications for the upcoming school year.</p>
        <a
          href="https://docs.google.com/forms/d/1CuhqVLxdc6ujO8y3FLcWLoVdVuoKK6SDI2h0ay5Hulo/"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary text-sm w-full text-center"
        >
          Pre-Enroll Today
        </a>
        <a
          href="https://go.boarddocs.com/fl/palmbeach/Board.nsf/files/D97JBY4C73BA/$file/2026-2027%20Calendar%20Final.pdf"
          target="_blank"
          rel="noopener noreferrer"
          class="mt-3 inline-flex items-center gap-2 text-navy-300 hover:text-gold-400 transition-colors text-sm"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          2026-2027 School Calendar
        </a>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-navy-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-navy-400 text-sm">
        &copy; {currentYear} Palm Beach Academy of Sports and Arts. All rights reserved.
      </p>
      <p class="text-navy-500 text-xs">
        A tuition-free public charter school
      </p>
    </div>
  </div>
</footer>
