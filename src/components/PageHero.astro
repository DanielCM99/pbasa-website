---
interface Props {
  title: string;
  subtitle?: string;
  bgImage?: string;
}

const { title, subtitle, bgImage = '/images/hero-bg.jpg' } = Astro.props;
---

<section class="page-hero">
  <img
    src={bgImage}
    alt=""
    class="absolute inset-0 w-full h-full object-cover"
    loading="eager"
  />
  <div class="page-hero-overlay"></div>
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <div class="gold-divider mx-auto mb-6"></div>
    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-heading font-bold mb-6">{title}</h1>
    {subtitle && <p class="text-xl text-navy-200 max-w-2xl mx-auto">{subtitle}</p>}
  </div>
</section>
