---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home" description="Palm Beach Academy of Sports and Arts - A tuition-free K-8 public charter school in West Palm Beach. Classical academics, arts, and athletics.">

  <!-- Hero Section -->
  <section class="relative min-h-[90vh] flex items-center bg-navy-900 overflow-hidden">
    <img
      src="/images/hero-bg.jpg"
      alt="Students at Palm Beach Academy"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-navy-950/95 via-navy-900/85 to-navy-900/50"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-32">
      <div class="max-w-3xl">
        <div class="flex items-center gap-3 mb-6">
          <div class="gold-divider"></div>
          <span class="text-gold-400 font-semibold text-sm uppercase tracking-widest">Now Enrolling K-8</span>
        </div>
        <h1 class="text-5xl sm:text-6xl lg:text-7xl font-heading font-bold text-white leading-tight mb-6">
          Where <span class="text-gold-400">Potential</span> Becomes
          <span class="text-gold-400">Purpose</span>
        </h1>
        <p class="text-xl text-navy-200 leading-relaxed mb-10 max-w-2xl">
          A tuition-free K-8 public charter school in West Palm Beach empowering every student through classical academics, the arts, and athletics.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="https://docs.google.com/forms/d/1CuhqVLxdc6ujO8y3FLcWLoVdVuoKK6SDI2h0ay5Hulo/" target="_blank" rel="noopener noreferrer" class="btn-primary text-lg">
            Pre-Enroll Now
            <svg class="w-5 h-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a href="/about" class="btn-secondary text-lg">Learn More</a>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 animate-bounce">
      <svg class="w-6 h-6 text-gold-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </section>

  <!-- Pillars Section (PRIORITY) -->
  <section class="section-padding bg-white" id="pillars">
    <div class="container-narrow">
      <div class="text-center mb-16">
        <span class="text-gold-600 font-semibold text-sm uppercase tracking-widest">Our Foundation</span>
        <h2 class="text-4xl sm:text-5xl font-heading font-bold text-navy-900 mt-3 mb-6">Our Pillars</h2>
        <div class="gold-divider mx-auto mb-6"></div>
        <p class="text-lg text-navy-600 max-w-3xl mx-auto">
          At Palm Beach Academy of Sports and Arts, our culture and learning are guided by five core pillars that shape both character and achievement.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-6 mb-12">
        <!-- Loyalty -->
        <div class="pillar-card text-center group">
          <div class="w-16 h-16 bg-navy-50 rounded-2xl flex items-center justify-center mx-auto mb-5 group-hover:bg-gold-50 transition-colors">
            <svg class="w-8 h-8 text-navy-800" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <h3 class="text-xl font-heading font-bold text-navy-900 mb-3">Loyalty</h3>
          <p class="text-navy-600 text-sm leading-relaxed">Building a strong sense of commitment to community, teamwork, and supporting one another.</p>
        </div>

        <!-- Integrity -->
        <div class="pillar-card text-center group">
          <div class="w-16 h-16 bg-navy-50 rounded-2xl flex items-center justify-center mx-auto mb-5 group-hover:bg-gold-50 transition-colors">
            <svg class="w-8 h-8 text-navy-800" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3" />
            </svg>
          </div>
          <h3 class="text-xl font-heading font-bold text-navy-900 mb-3">Integrity</h3>
          <p class="text-navy-600 text-sm leading-relaxed">Encouraging honesty, responsibility, and ethical decision-making in all actions.</p>
        </div>

        <!-- Optimism -->
        <div class="pillar-card text-center group">
          <div class="w-16 h-16 bg-navy-50 rounded-2xl flex items-center justify-center mx-auto mb-5 group-hover:bg-gold-50 transition-colors">
            <svg class="w-8 h-8 text-navy-800" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-heading font-bold text-navy-900 mb-3">Optimism</h3>
          <p class="text-navy-600 text-sm leading-relaxed">Inspiring a positive mindset, resilience, and confidence in overcoming challenges.</p>
        </div>

        <!-- Nobility -->
        <div class="pillar-card text-center group">
          <div class="w-16 h-16 bg-navy-50 rounded-2xl flex items-center justify-center mx-auto mb-5 group-hover:bg-gold-50 transition-colors">
            <svg class="w-8 h-8 text-navy-800" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-heading font-bold text-navy-900 mb-3">Nobility</h3>
          <p class="text-navy-600 text-sm leading-relaxed">Promoting respect, kindness, and a commitment to serving others.</p>
        </div>

        <!-- Strength -->
        <div class="pillar-card text-center group">
          <div class="w-16 h-16 bg-navy-50 rounded-2xl flex items-center justify-center mx-auto mb-5 group-hover:bg-gold-50 transition-colors">
            <svg class="w-8 h-8 text-navy-800" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="text-xl font-heading font-bold text-navy-900 mb-3">Strength</h3>
          <p class="text-navy-600 text-sm leading-relaxed">Developing perseverance, courage, and determination both academically and personally.</p>
        </div>
      </div>

      <div class="text-center">
        <p class="text-navy-700 text-lg font-medium italic max-w-3xl mx-auto">
          These values inspire our students to lead with character, pursue excellence in academics, arts, and athletics, and develop the confidence and resilience needed to succeed in school and in life.
        </p>
      </div>
    </div>
  </section>

  <!-- Three Program Areas -->
  <section class="section-padding bg-navy-50">
    <div class="container-narrow">
      <div class="text-center mb-16">
        <span class="text-gold-600 font-semibold text-sm uppercase tracking-widest">What We Offer</span>
        <h2 class="text-4xl sm:text-5xl font-heading font-bold text-navy-900 mt-3 mb-6">A Well-Rounded Education</h2>
        <div class="gold-divider mx-auto"></div>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <!-- Academics -->
        <div class="card group">
          <div class="h-48 bg-gradient-to-br from-navy-800 to-navy-600 flex items-center justify-center">
            <svg class="w-20 h-20 text-gold-400 group-hover:scale-110 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
          </div>
          <div class="p-8">
            <h3 class="text-2xl font-heading font-bold text-navy-900 mb-3">Classical Academics</h3>
            <p class="text-navy-600 leading-relaxed mb-6">Inquiry-based learning, critical thinking, and problem-solving across all grade levels K-8, with Spanish language instruction.</p>
            <a href="/academics" class="inline-flex items-center text-gold-600 font-semibold hover:text-gold-700 transition-colors">
              Explore Academics
              <svg class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>
        </div>

        <!-- Arts -->
        <div class="card group">
          <div class="h-48 bg-gradient-to-br from-gold-600 to-gold-400 flex items-center justify-center">
            <svg class="w-20 h-20 text-navy-900 group-hover:scale-110 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" />
            </svg>
          </div>
          <div class="p-8">
            <h3 class="text-2xl font-heading font-bold text-navy-900 mb-3">The Arts</h3>
            <p class="text-navy-600 leading-relaxed mb-6">Visual arts, music, dance, and theater programs that develop self-expression, creativity, and cultural appreciation.</p>
            <a href="/academics" class="inline-flex items-center text-gold-600 font-semibold hover:text-gold-700 transition-colors">
              Discover Programs
              <svg class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>
        </div>

        <!-- Athletics -->
        <div class="card group">
          <div class="h-48 bg-gradient-to-br from-navy-600 to-navy-400 flex items-center justify-center">
            <svg class="w-20 h-20 text-gold-400 group-hover:scale-110 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <div class="p-8">
            <h3 class="text-2xl font-heading font-bold text-navy-900 mb-3">Athletics</h3>
            <p class="text-navy-600 leading-relaxed mb-6">Daily movement and sports including basketball, golf, tennis, soccer, flag football, and more to build strong bodies and minds.</p>
            <a href="/athletics" class="inline-flex items-center text-gold-600 font-semibold hover:text-gold-700 transition-colors">
              View Athletics
              <svg class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Mission Highlight -->
  <section class="section-padding bg-navy-900 text-white relative overflow-hidden">
    <div class="absolute top-0 right-0 w-96 h-96 bg-gold-500/5 rounded-full -translate-y-1/2 translate-x-1/2"></div>
    <div class="absolute bottom-0 left-0 w-64 h-64 bg-gold-500/5 rounded-full translate-y-1/2 -translate-x-1/2"></div>
    <div class="container-narrow relative z-10">
      <div class="max-w-4xl mx-auto text-center">
        <span class="text-gold-400 font-semibold text-sm uppercase tracking-widest">Our Mission</span>
        <h2 class="text-3xl sm:text-4xl font-heading font-bold mt-3 mb-8">Empowering Every Student</h2>
        <div class="gold-divider mx-auto mb-8"></div>
        <p class="text-xl text-navy-200 leading-relaxed mb-10">
          The mission of Palm Beach Academy of Sports and Arts Charter School is to empower every student to reach their full potential within an empathetic, encouraging, and supportive learning environment. Through a balanced focus on classical academics, the arts, and athletics, we partner with families to challenge and inspire students with rigorous classroom instruction, meaningful mentorship, and enriching after-school programs that foster character, creativity, and lifelong success.
        </p>
        <a href="/about" class="btn-primary">
          About Our School
          <svg class="w-5 h-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Student Gallery -->
  <section class="section-padding bg-white">
    <div class="container-narrow">
      <div class="text-center mb-12">
        <span class="text-gold-600 font-semibold text-sm uppercase tracking-widest">Our Community</span>
        <h2 class="text-4xl font-heading font-bold text-navy-900 mt-3 mb-6">Our Students</h2>
        <div class="gold-divider mx-auto"></div>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
        <div class="aspect-square rounded-2xl overflow-hidden">
          <img src="/images/student-1.jpg" alt="PBASA Student" class="w-full h-full object-cover hover:scale-110 transition-transform duration-500" loading="lazy" />
        </div>
        <div class="aspect-square rounded-2xl overflow-hidden">
          <img src="/images/student-2.jpg" alt="PBASA Student" class="w-full h-full object-cover hover:scale-110 transition-transform duration-500" loading="lazy" />
        </div>
        <div class="aspect-square rounded-2xl overflow-hidden">
          <img src="/images/student-3.jpg" alt="PBASA Student" class="w-full h-full object-cover hover:scale-110 transition-transform duration-500" loading="lazy" />
        </div>
        <div class="aspect-square rounded-2xl overflow-hidden">
          <img src="/images/student-5.jpg" alt="PBASA Student" class="w-full h-full object-cover hover:scale-110 transition-transform duration-500" loading="lazy" />
        </div>
        <div class="aspect-square rounded-2xl overflow-hidden">
          <img src="/images/student-7.jpg" alt="PBASA Student" class="w-full h-full object-cover hover:scale-110 transition-transform duration-500" loading="lazy" />
        </div>
        <div class="aspect-square rounded-2xl overflow-hidden">
          <img src="/images/student-8.jpg" alt="PBASA Student" class="w-full h-full object-cover hover:scale-110 transition-transform duration-500" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="relative py-24 overflow-hidden">
    <img src="/images/classroom.jpeg" alt="" class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
    <div class="absolute inset-0 bg-gradient-to-r from-navy-900/95 to-navy-800/90"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl sm:text-4xl font-heading font-bold text-white mb-6">Ready to Join Our Community?</h2>
      <p class="text-xl text-navy-200 mb-10 max-w-2xl mx-auto">
        Pre-enrollment is now open for the upcoming school year. Give your child the opportunity to thrive academically, artistically, and athletically.
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="https://docs.google.com/forms/d/1CuhqVLxdc6ujO8y3FLcWLoVdVuoKK6SDI2h0ay5Hulo/" target="_blank" rel="noopener noreferrer" class="btn-primary text-lg">
          Start Pre-Enrollment
        </a>
        <a href="/enrollment" class="btn-secondary text-lg">
          Enrollment Details
        </a>
      </div>
    </div>
  </section>

</Layout>
