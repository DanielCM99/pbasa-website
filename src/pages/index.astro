---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home" description="Palm Beach Academy of Sports and Arts - A tuition-free K-8 public charter school in West Palm Beach. Classical academics, arts, and athletics.">

  <!-- Hero Section -->
  <section class="relative min-h-[90vh] flex items-center bg-navy-900 overflow-hidden">
    <img
      src="/images/hero-bg.jpg"
      alt="Students at Palm Beach Academy"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-navy-950/95 via-navy-900/85 to-navy-900/50"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-32">
      <div class="max-w-3xl">
        <div class="flex items-center gap-3 mb-6">
          <div class="gold-divider"></div>
          <span class="text-gold-400 font-semibold text-sm uppercase tracking-widest">Home of the Lions &bull; Now Enrolling K-8</span>
        </div>
        <h1 class="text-5xl sm:text-6xl lg:text-7xl font-heading font-bold text-white leading-tight mb-6">
          Where <span class="text-gold-400">Potential</span> Becomes
          <span class="text-gold-400">Purpose</span>
        </h1>
        <p class="text-xl text-navy-200 leading-relaxed mb-10 max-w-2xl">
          A tuition-free K-8 public charter school in West Palm Beach empowering every student through classical academics, the arts, and athletics.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="https://docs.google.com/forms/d/1CuhqVLxdc6ujO8y3FLcWLoVdVuoKK6SDI2h0ay5Hulo/" target="_blank" rel="noopener noreferrer" class="btn-primary text-lg">
            Pre-Enroll Now
            <svg class="w-5 h-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a href="/about" class="btn-secondary text-lg">Learn More</a>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 animate-bounce">
      <svg class="w-6 h-6 text-gold-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </section>

  <!-- Recent Updates -->
  <section class="py-10 bg-gold-50 border-b border-gold-200" id="updates">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-3 mb-6">
        <div class="gold-divider"></div>
        <span class="text-gold-700 font-semibold text-sm uppercase tracking-widest">Recent Updates</span>
      </div>

      <!-- Board Meeting Notice — March 23, 2026 -->
      <div class="bg-white rounded-2xl shadow-sm border border-gold-200 overflow-hidden">
        <div class="bg-navy-900 px-6 py-4">
          <div class="flex items-center gap-3">
            <svg class="w-6 h-6 text-gold-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <h3 class="text-xl font-heading font-bold text-white">Governing Board Meeting</h3>
          </div>
        </div>
        <div class="p-6 sm:p-8">
          <div class="grid sm:grid-cols-2 gap-6 mb-6">
            <div>
              <p class="text-navy-900 font-bold text-lg mb-1">Palm Beach Academy of Sports and Arts</p>
              <p class="text-navy-700 font-semibold">Governing Board Meeting</p>
            </div>
            <div class="space-y-2">
              <div class="flex items-center gap-2 text-navy-700">
                <svg class="w-5 h-5 text-gold-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                <span><strong>Monday, March 23, 2026</strong></span>
              </div>
              <div class="flex items-center gap-2 text-navy-700">
                <svg class="w-5 h-5 text-gold-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span><strong>6:00 PM</strong></span>
              </div>
            </div>
          </div>

          <div class="grid sm:grid-cols-2 gap-6 mb-6">
            <!-- Virtual Access -->
            <div class="bg-navy-50 rounded-xl p-5">
              <h4 class="text-navy-900 font-bold mb-2 flex items-center gap-2">
                <svg class="w-5 h-5 text-gold-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
                </svg>
                Join via Zoom
              </h4>
              <a
                href="https://us02web.zoom.us/j/82328718144?pwd=dHNBTjNBRmdRcEQ1OXQrbTEweGt4QT09"
                target="_blank"
                rel="noopener noreferrer"
                class="text-gold-600 hover:text-gold-700 font-medium text-sm break-all transition-colors"
              >
                Join Virtual Meeting
              </a>
            </div>

            <!-- In-Person Access -->
            <div class="bg-navy-50 rounded-xl p-5">
              <h4 class="text-navy-900 font-bold mb-2 flex items-center gap-2">
                <svg class="w-5 h-5 text-gold-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                In-Person Attendance
              </h4>
              <p class="text-navy-600 text-sm">In-person attendance is available. See the full agenda for access point details.</p>
            </div>
          </div>

          <!-- Contact Info -->
          <div class="border-t border-navy-100 pt-5 space-y-3">
            <p class="text-navy-600 text-sm">
              <strong>Accommodations:</strong> Contact Mark at
              <a href="tel:5616921313" class="text-gold-600 hover:text-gold-700 font-medium transition-colors">561-692-1313</a>
              at least two days prior to the meeting.
            </p>
            <p class="text-navy-600 text-sm">
              <strong>Written Submissions:</strong> Contact Stacy Harris at
              <a href="mailto:stacy@pbasa.org" class="text-gold-600 hover:text-gold-700 font-medium transition-colors">stacy@pbasa.org</a>
              or <a href="tel:3038294035" class="text-gold-600 hover:text-gold-700 font-medium transition-colors">303-829-4035</a>.
            </p>
          </div>

          <!-- CTA -->
          <div class="mt-6">
            <a
              href="/documents/PBASA-Agenda-March-20-2026.pdf"
              target="_blank"
              rel="noopener noreferrer"
              class="btn-primary inline-flex items-center"
            >
              <svg class="w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              View Full Agenda (PDF)
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- LIONS Pillars Section -->
  <section class="section-padding bg-white" id="pillars">
    <div class="container-narrow">
      <div class="text-center mb-16">
        <span class="text-gold-600 font-semibold text-sm uppercase tracking-widest">Home of the Lions</span>
        <h2 class="text-4xl sm:text-5xl font-heading font-bold text-navy-900 mt-3 mb-4">The <span class="text-gold-500">LIONS</span> Pillars</h2>
        <p class="text-navy-500 font-semibold text-lg mb-4">Loyalty &bull; Integrity &bull; Optimism &bull; Nobility &bull; Strength</p>
        <div class="gold-divider mx-auto mb-6"></div>
        <p class="text-lg text-navy-600 max-w-3xl mx-auto">
          As proud Lions, our students live by five core pillars that guide character development, academic growth, and leadership every day.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-6 mb-12">
        <!-- Loyalty -->
        <div class="pillar-card text-center group">
          <div class="text-4xl font-heading font-bold text-gold-500 mb-2">L</div>
          <h3 class="text-xl font-heading font-bold text-navy-900 mb-3">Loyalty</h3>
          <p class="text-navy-600 text-sm leading-relaxed">Building a strong sense of commitment to community, teamwork, and supporting one another.</p>
        </div>

        <!-- Integrity -->
        <div class="pillar-card text-center group">
          <div class="text-4xl font-heading font-bold text-gold-500 mb-2">I</div>
          <h3 class="text-xl font-heading font-bold text-navy-900 mb-3">Integrity</h3>
          <p class="text-navy-600 text-sm leading-relaxed">Encouraging honesty, responsibility, and ethical decision-making in all actions.</p>
        </div>

        <!-- Optimism -->
        <div class="pillar-card text-center group">
          <div class="text-4xl font-heading font-bold text-gold-500 mb-2">O</div>
          <h3 class="text-xl font-heading font-bold text-navy-900 mb-3">Optimism</h3>
          <p class="text-navy-600 text-sm leading-relaxed">Inspiring a positive mindset, resilience, and confidence in overcoming challenges.</p>
        </div>

        <!-- Nobility -->
        <div class="pillar-card text-center group">
          <div class="text-4xl font-heading font-bold text-gold-500 mb-2">N</div>
          <h3 class="text-xl font-heading font-bold text-navy-900 mb-3">Nobility</h3>
          <p class="text-navy-600 text-sm leading-relaxed">Promoting respect, kindness, and a commitment to serving others.</p>
        </div>

        <!-- Strength -->
        <div class="pillar-card text-center group">
          <div class="text-4xl font-heading font-bold text-gold-500 mb-2">S</div>
          <h3 class="text-xl font-heading font-bold text-navy-900 mb-3">Strength</h3>
          <p class="text-navy-600 text-sm leading-relaxed">Developing perseverance, courage, and determination both academically and personally.</p>
        </div>
      </div>

      <div class="text-center">
        <p class="text-navy-700 text-lg font-medium italic max-w-3xl mx-auto">
          These pillars are integrated throughout our academics, athletics, arts programs, and school culture, helping our Lions grow into confident, principled, and compassionate leaders.
        </p>
      </div>
    </div>
  </section>

  <!-- Image Feature Section -->
  <section class="relative">
    <div class="grid lg:grid-cols-2">
      <div class="relative h-72 lg:h-[480px] overflow-hidden">
        <img src="/images/students-hallway.jpg" alt="PBASA students in the hallway" class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
      </div>
      <div class="bg-navy-900 text-white flex items-center p-10 lg:p-16">
        <div>
          <span class="text-gold-400 font-semibold text-sm uppercase tracking-widest">Our Pride</span>
          <h2 class="text-3xl sm:text-4xl font-heading font-bold mt-3 mb-6">Join the Lions &mdash; Belong, Grow, and Succeed</h2>
          <div class="gold-divider mb-6"></div>
          <p class="text-navy-200 leading-relaxed text-lg mb-8">
            At Palm Beach Academy of Sports and Arts, every student is known, valued, and supported. Our close-knit community fosters meaningful relationships between students, teachers, and families.
          </p>
          <a href="/enrollment" class="btn-primary">
            Join Our School
            <svg class="w-5 h-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Three Program Areas -->
  <section class="section-padding bg-navy-50">
    <div class="container-narrow">
      <div class="text-center mb-16">
        <span class="text-gold-600 font-semibold text-sm uppercase tracking-widest">What We Offer</span>
        <h2 class="text-4xl sm:text-5xl font-heading font-bold text-navy-900 mt-3 mb-6">A Well-Rounded Education</h2>
        <div class="gold-divider mx-auto"></div>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <!-- Academics -->
        <div class="card group">
          <div class="h-48 overflow-hidden relative">
            <img src="/images/classroom.jpeg" alt="Classroom learning" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-navy-900/60 to-transparent"></div>
          </div>
          <div class="p-8">
            <h3 class="text-2xl font-heading font-bold text-navy-900 mb-3">Classical Academics</h3>
            <p class="text-navy-600 leading-relaxed mb-6">Inquiry-based learning, critical thinking, and problem-solving across all grade levels K-8, with Spanish language instruction.</p>
            <a href="/academics" class="inline-flex items-center text-gold-600 font-semibold hover:text-gold-700 transition-colors">
              Explore Academics
              <svg class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>
        </div>

        <!-- Arts -->
        <div class="card group">
          <div class="h-48 overflow-hidden relative">
            <img src="/images/arts-class.jpg" alt="Students painting in arts class" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-gold-700/60 to-transparent"></div>
          </div>
          <div class="p-8">
            <h3 class="text-2xl font-heading font-bold text-navy-900 mb-3">The Arts</h3>
            <p class="text-navy-600 leading-relaxed mb-6">Visual arts, music, dance, and theater programs that develop self-expression, creativity, and cultural appreciation.</p>
            <a href="/academics" class="inline-flex items-center text-gold-600 font-semibold hover:text-gold-700 transition-colors">
              Discover Programs
              <svg class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>
        </div>

        <!-- Athletics -->
        <div class="card group">
          <div class="h-48 overflow-hidden relative">
            <img src="/images/athletics-action.jpg" alt="Students running in athletics" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-navy-700/60 to-transparent"></div>
          </div>
          <div class="p-8">
            <h3 class="text-2xl font-heading font-bold text-navy-900 mb-3">Athletics</h3>
            <p class="text-navy-600 leading-relaxed mb-6">Daily movement and sports including basketball, golf, tennis, soccer, flag football, and more to build strong bodies and minds.</p>
            <a href="/athletics" class="inline-flex items-center text-gold-600 font-semibold hover:text-gold-700 transition-colors">
              View Athletics
              <svg class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Mission Highlight -->
  <section class="section-padding bg-navy-900 text-white relative overflow-hidden">
    <div class="absolute top-0 right-0 w-96 h-96 bg-gold-500/5 rounded-full -translate-y-1/2 translate-x-1/2"></div>
    <div class="absolute bottom-0 left-0 w-64 h-64 bg-gold-500/5 rounded-full translate-y-1/2 -translate-x-1/2"></div>
    <div class="container-narrow relative z-10">
      <div class="max-w-4xl mx-auto text-center">
        <span class="text-gold-400 font-semibold text-sm uppercase tracking-widest">Our Mission</span>
        <h2 class="text-3xl sm:text-4xl font-heading font-bold mt-3 mb-8">Empowering Every Student</h2>
        <div class="gold-divider mx-auto mb-8"></div>
        <p class="text-xl text-navy-200 leading-relaxed mb-10">
          The mission of Palm Beach Academy of Sports and Arts Charter School is to empower every student to reach their full potential within an empathetic, encouraging, and supportive learning environment. Through a balanced focus on classical academics, the arts, and athletics, we partner with families to challenge and inspire students with rigorous classroom instruction, meaningful mentorship, and enriching after-school programs that foster character, creativity, and lifelong success.
        </p>
        <a href="/about" class="btn-primary">
          About Our School
          <svg class="w-5 h-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Student Gallery -->
  <section class="section-padding bg-white">
    <div class="container-narrow">
      <div class="text-center mb-12">
        <span class="text-gold-600 font-semibold text-sm uppercase tracking-widest">Our Pride</span>
        <h2 class="text-4xl font-heading font-bold text-navy-900 mt-3 mb-6">Our Sponsors</h2>
        <div class="gold-divider mx-auto"></div>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
        <div class="aspect-square rounded-2xl overflow-hidden">
          <img src="/images/sponsor-bluesky.jpg" alt="Blue Sky" class="w-full h-full object-cover hover:scale-110 transition-transform duration-500" loading="lazy" />
        </div>
        <div class="aspect-square rounded-2xl overflow-hidden">
          <img src="/images/sponsor-southstar.jpg" alt="SouthStar Communities" class="w-full h-full object-cover hover:scale-110 transition-transform duration-500" loading="lazy" />
        </div>
        <div class="aspect-square rounded-2xl overflow-hidden">
          <img src="/images/student-2.jpg" alt="PBASA Student" class="w-full h-full object-cover hover:scale-110 transition-transform duration-500" loading="lazy" />
        </div>
        <div class="aspect-square rounded-2xl overflow-hidden">
          <img src="/images/sponsor-16.jpg" alt="Sponsor" class="w-full h-full object-cover hover:scale-110 transition-transform duration-500" loading="lazy" />
        </div>
        <div class="aspect-square rounded-2xl overflow-hidden">
          <img src="/images/sponsor-561.png" alt="561 Signs &amp; Printing" class="w-full h-full object-cover hover:scale-110 transition-transform duration-500" loading="lazy" />
        </div>
        <div class="aspect-square rounded-2xl overflow-hidden">
          <img src="/images/student-8.jpg" alt="PBASA Student" class="w-full h-full object-cover hover:scale-110 transition-transform duration-500" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="relative py-24 overflow-hidden">
    <img src="/images/classroom.jpeg" alt="" class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
    <div class="absolute inset-0 bg-gradient-to-r from-navy-900/95 to-navy-800/90"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl sm:text-4xl font-heading font-bold text-white mb-6">Ready to Become a Lion?</h2>
      <p class="text-xl text-navy-200 mb-10 max-w-2xl mx-auto">
        Pre-enrollment is now open for the upcoming school year. Give your child the opportunity to thrive academically, artistically, and athletically.
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="https://docs.google.com/forms/d/1CuhqVLxdc6ujO8y3FLcWLoVdVuoKK6SDI2h0ay5Hulo/" target="_blank" rel="noopener noreferrer" class="btn-primary text-lg">
          Start Pre-Enrollment
        </a>
        <a href="/enrollment" class="btn-secondary text-lg">
          Enrollment Details
        </a>
      </div>
    </div>
  </section>

</Layout>
